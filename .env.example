# Anthropic API key para los scripts de IA editorial.
# Crear en https://console.anthropic.com/ y añadir a .env (no comitear).
ANTHROPIC_API_KEY=

# Modelo por defecto para los scripts editoriales.
# Sonnet 4.6 da el mejor balance calidad/coste para escritura técnica.
ANTHROPIC_MODEL=claude-sonnet-4-6
