---
// Panel editorial Decap CMS — página independiente del layout del sitio.
// El config.yml vive en /public/admin/config.yml (servido como estático).
export const prerender = true;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Nexo Mundial · Panel editorial</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
  </head>
  <body>
    <!-- Sveltia CMS: fork moderno de Decap. Auth vía GitHub OAuth
         (sin Netlify Identity), compatible con cualquier hosting estático. -->
    <script is:inline type="module" src="https://unpkg.com/@sveltia/cms/dist/sveltia-cms.js"></script>
  </body>
</html>
