---
import { Icon } from 'astro-icon/components';
import { profileConfig, siteConfig } from "../config";
import { CATEGORY_LIST } from "../lib/categories";
const year = new Date().getFullYear();
---

<footer class="border-t border-black/[0.07] dark:border-white/[0.08] bg-[var(--page-bg)] mt-16">
    <div class="max-w-[var(--page-width)] mx-auto px-4 md:px-6 lg:px-8 py-12 md:py-14">
        <div class="grid grid-cols-2 md:grid-cols-5 gap-10 md:gap-8">
            <!-- Brand (swap entre light/dark según modo) -->
            <div class="col-span-2 md:col-span-2 max-w-md">
                <a href="/" class="inline-block mb-3" aria-label={siteConfig.title}>
                    <img
                        src="/logo-light.png"
                        alt={siteConfig.title}
                        width="2172"
                        height="724"
                        class="block dark:hidden h-8 w-auto"
                        loading="lazy"
                    />
                    <img
                        src="/logo-dark.png"
                        alt={siteConfig.title}
                        width="2172"
                        height="724"
                        class="hidden dark:block h-8 w-auto"
                        loading="lazy"
                    />
                </a>
                <p class="text-sm text-black/60 dark:text-white/60 leading-relaxed mb-5">
                    {profileConfig.bio}
                </p>
                <div class="flex items-center gap-3">
                    {profileConfig.links.map((l) => (
                        <a href={l.url} target="_blank" rel="noopener noreferrer" aria-label={l.name}
                           class="text-black/45 dark:text-white/45 hover:text-[var(--primary)] transition">
                            <Icon name={l.icon} size="1.15rem"></Icon>
                        </a>
                    ))}
                </div>
            </div>

            <!-- Categorías -->
            <div>
                <p class="text-[0.7rem] uppercase tracking-[0.16em] font-semibold text-black/55 dark:text-white/55 mb-4">Temas</p>
                <ul class="text-sm space-y-2.5">
                    {CATEGORY_LIST.map(cat => (
                        <li><a href={`/categorias/${cat.slug}/`} class="text-black/65 dark:text-white/65 hover:text-[var(--primary)] transition">{cat.short}</a></li>
                    ))}
                </ul>
            </div>

            <!-- Sitio -->
            <div>
                <p class="text-[0.7rem] uppercase tracking-[0.16em] font-semibold text-black/55 dark:text-white/55 mb-4">Sitio</p>
                <ul class="text-sm space-y-2.5">
                    <li><a href="/about/" class="text-black/65 dark:text-white/65 hover:text-[var(--primary)] transition">Sobre el proyecto</a></li>
                    <li><a href="/categorias/" class="text-black/65 dark:text-white/65 hover:text-[var(--primary)] transition">Todas las categorías</a></li>
                    <li><a href="/glosario/" class="text-black/65 dark:text-white/65 hover:text-[var(--primary)] transition">Glosario</a></li>
                    <li><a href="/rss.xml" class="text-black/65 dark:text-white/65 hover:text-[var(--primary)] transition">RSS</a></li>
                </ul>
            </div>

            <!-- Legal -->
            <div>
                <p class="text-[0.7rem] uppercase tracking-[0.16em] font-semibold text-black/55 dark:text-white/55 mb-4">Legal</p>
                <ul class="text-sm space-y-2.5">
                    <li><a href="/contacto/" class="text-black/65 dark:text-white/65 hover:text-[var(--primary)] transition">Contacto</a></li>
                    <li><a href="/privacidad/" class="text-black/65 dark:text-white/65 hover:text-[var(--primary)] transition">Privacidad</a></li>
                    <li><a href="/terminos/" class="text-black/65 dark:text-white/65 hover:text-[var(--primary)] transition">Términos de uso</a></li>
                    <li><a href="/politica-ia/" class="text-black/65 dark:text-white/65 hover:text-[var(--primary)] transition">Política de IA</a></li>
                </ul>
            </div>
        </div>

        <div class="mt-10 pt-6 border-t border-black/[0.06] dark:border-white/[0.06]">
            <p class="text-xs text-black/45 dark:text-white/45">
                © {year} {profileConfig.name}. Contenido publicado bajo licencia
                <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--primary)] transition">CC BY-NC-SA 4.0</a>.
            </p>
        </div>
    </div>
</footer>
