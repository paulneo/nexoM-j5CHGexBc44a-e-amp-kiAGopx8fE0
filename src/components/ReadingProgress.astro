---
/**
 * Barra fina arriba que avanza al hacer scroll dentro del article
 * indicado por el selector. Estilo Medium / Substack.
 */

interface Props {
    target?: string;
}
const { target = '.markdown-content' } = Astro.props;
---

<div
    id="reading-progress"
    role="progressbar"
    aria-label="Progreso de lectura"
    aria-valuemin="0"
    aria-valuemax="100"
    aria-valuenow="0"
    data-target={target}
    class="fixed top-0 inset-x-0 h-[3px] z-50 pointer-events-none"
>
    <div
        id="reading-progress-bar"
        class="h-full bg-gradient-to-r from-[var(--primary)] via-emerald-500 to-teal-400 origin-left scale-x-0 transition-transform duration-150 ease-out"
        style="transform-origin: left center;"
    ></div>
</div>

<script>
function bindReadingProgress() {
    const wrapper = document.getElementById('reading-progress');
    const bar = document.getElementById('reading-progress-bar');
    if (!wrapper || !bar) return;

    const targetSelector = wrapper.dataset.target ?? '.markdown-content';
    const target = document.querySelector<HTMLElement>(targetSelector);
    if (!target) {
        wrapper.classList.add('!hidden');
        return;
    }

    let ticking = false;
    const update = () => {
        const rect = target.getBoundingClientRect();
        const total = rect.height + window.innerHeight * 0.4;
        const scrolled = Math.max(0, -rect.top);
        const ratio = Math.min(1, Math.max(0, scrolled / total));
        bar.style.transform = `scaleX(${ratio})`;
        wrapper.setAttribute('aria-valuenow', String(Math.round(ratio * 100)));
        ticking = false;
    };

    const onScroll = () => {
        if (!ticking) {
            window.requestAnimationFrame(update);
            ticking = true;
        }
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
}

bindReadingProgress();
document.addEventListener('astro:after-swap', bindReadingProgress);
</script>
