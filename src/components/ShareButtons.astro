---
import { Icon } from 'astro-icon/components'

interface Props {
  title: string
  url: string
  description?: string
  tags?: string[]
  variant?: 'inline' | 'compact'
}

const { title, url, description = '', tags = [], variant = 'inline' } = Astro.props

const encodedUrl = encodeURIComponent(url)
const encodedTitle = encodeURIComponent(title)
const encodedDescription = encodeURIComponent(description)
// WhatsApp/Telegram/email: título + descripción + URL en un solo bloque
const encodedShare = encodeURIComponent(
  description ? `${title}\n\n${description}\n\n${url}` : `${title} ${url}`,
)
// X/Twitter: título + tags hashtag-style (X soporta varios hashtags, separados por coma)
const xHashtags = tags.length
  ? `&hashtags=${tags.slice(0, 3).map((t) => t.replace(/-/g, '')).join(',')}`
  : ''
// Facebook: usamos sharer.php solo con `u` para máxima compatibilidad.
// El parámetro `quote` ya está deprecado (ignora) y agregarlo, junto
// con `hashtag`, hace que sharer.php se cuelgue en "Publicando..." en
// algunos casos. Mantenemos la URL mínima y la descripción + tags
// viajan al portapapeles para que el editor pegue en el compose.
const emailBody = description ? `${title}\n\n${description}\n\nLeer artículo: ${url}` : `${title}\n\n${url}`
const encodedEmailBody = encodeURIComponent(emailBody)

const networks = [
  {
    name: 'WhatsApp',
    href: `https://wa.me/?text=${encodedShare}`,
    icon: 'fa6-brands:whatsapp',
    hover: 'hover:bg-[#25D366] hover:text-white hover:border-[#25D366]',
  },
  {
    name: 'LinkedIn',
    href: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`,
    icon: 'fa6-brands:linkedin-in',
    hover: 'hover:bg-[#0A66C2] hover:text-white hover:border-[#0A66C2]',
  },
  {
    name: 'X',
    href: `https://x.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}${xHashtags}`,
    icon: 'fa6-brands:x-twitter',
    hover: 'hover:bg-black hover:text-white hover:border-black dark:hover:bg-white dark:hover:text-black dark:hover:border-white',
  },
  {
    name: 'Facebook',
    href: 'https://www.facebook.com/',
    icon: 'fa6-brands:facebook-f',
    hover: 'hover:bg-[#1877F2] hover:text-white hover:border-[#1877F2]',
    // sharer.php de FB se cuelga en 'Publicando...' después del click
    // de Compartir, mientras que pegar la URL en el compose box normal
    // de la página sí publica bien. En vez de pelear contra el popup
    // roto, abrimos facebook.com directamente y copiamos al portapapeles
    // el texto rico para que el editor lo pegue en su propio compose.
    copyOnClick: true,
  },
  {
    name: 'Email',
    href: `mailto:?subject=${encodedTitle}&body=${encodedEmailBody}`,
    icon: 'material-symbols:mail-outline',
    hover: 'hover:bg-[var(--primary)] hover:text-white hover:border-[var(--primary)]',
  },
]
---

<section class:list={["share-buttons", variant === 'compact' ? 'mt-8' : 'mt-12 pt-8 border-t border-black/[0.08] dark:border-white/[0.1]']}>
  {variant === 'inline' && (
    <p class="text-[0.72rem] uppercase tracking-[0.16em] font-semibold text-black/55 dark:text-white/55 mb-4">
      Compartir este artículo
    </p>
  )}
  <div class="flex flex-wrap items-center gap-2.5">
    {networks.map((n) => (
      <a
        href={n.href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Compartir en ${n.name}`}
        data-share-copy-text={n.copyOnClick ? emailBody : undefined}
        class:list={["inline-flex items-center justify-center w-10 h-10 rounded-full border border-black/[0.1] dark:border-white/[0.12] text-black/65 dark:text-white/70 transition-all duration-200", n.hover]}
      >
        <Icon name={n.icon} class="w-4 h-4" />
      </a>
    ))}
    <button
      type="button"
      data-share-copy={url}
      aria-label="Copiar enlace al portapapeles"
      class="inline-flex items-center justify-center w-10 h-10 rounded-full border border-black/[0.1] dark:border-white/[0.12] text-black/65 dark:text-white/70 hover:bg-[var(--primary)] hover:text-white hover:border-[var(--primary)] transition-all duration-200"
    >
      <Icon name="material-symbols:link" class="w-4 h-4 share-icon-link" />
      <Icon name="material-symbols:check" class="w-4 h-4 share-icon-check hidden" />
    </button>
    <span data-share-copy-feedback class="text-xs text-black/55 dark:text-white/55 opacity-0 transition-opacity duration-200 ml-1">
      ¡Enlace copiado!
    </span>
  </div>
</section>

<script>
  const copyToClipboard = async (text: string) => {
    try {
      await navigator.clipboard.writeText(text)
    } catch {
      const ta = document.createElement('textarea')
      ta.value = text
      ta.style.position = 'fixed'
      ta.style.opacity = '0'
      document.body.appendChild(ta)
      ta.focus()
      ta.select()
      try { document.execCommand('copy') } catch {}
      document.body.removeChild(ta)
    }
  }

  const flashFeedback = (container: HTMLElement | null, message: string) => {
    const feedback = container?.querySelector<HTMLElement>('[data-share-copy-feedback]')
    if (!feedback) return
    feedback.textContent = message
    feedback.style.setProperty('opacity', '1')
    setTimeout(() => {
      feedback.style.setProperty('opacity', '0')
    }, 2400)
  }

  const wire = () => {
    // Botón explícito de "copiar link"
    document.querySelectorAll<HTMLButtonElement>('[data-share-copy]').forEach((btn) => {
      if (btn.dataset.shareWired === '1') return
      btn.dataset.shareWired = '1'
      btn.addEventListener('click', async () => {
        const url = btn.getAttribute('data-share-copy') ?? window.location.href
        await copyToClipboard(url)
        const linkIcon = btn.querySelector('.share-icon-link')
        const checkIcon = btn.querySelector('.share-icon-check')
        linkIcon?.classList.add('hidden')
        checkIcon?.classList.remove('hidden')
        flashFeedback(btn.parentElement, '¡Enlace copiado!')
        setTimeout(() => {
          linkIcon?.classList.remove('hidden')
          checkIcon?.classList.add('hidden')
        }, 1800)
      })
    })
    // Botones de redes que copian texto al portapapeles antes de abrir (Facebook)
    document.querySelectorAll<HTMLAnchorElement>('[data-share-copy-text]').forEach((link) => {
      if (link.dataset.shareWired === '1') return
      link.dataset.shareWired = '1'
      link.addEventListener('click', async () => {
        const text = link.getAttribute('data-share-copy-text') ?? ''
        if (!text) return
        await copyToClipboard(text)
        flashFeedback(link.parentElement, '✓ Texto copiado — pegalo en el compose de Facebook (Ctrl+V)')
      })
    })
  }
  wire()
  document.addEventListener('astro:after-swap', wire)
</script>
