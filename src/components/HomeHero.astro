---
import { Icon } from 'astro-icon/components';
---

<section class="relative -mx-4 md:-mx-6 lg:-mx-8 px-4 md:px-6 lg:px-8 mb-16 md:mb-24 lg:mb-32 overflow-hidden">
    <!-- Mesh gradient blobs de fondo (premium feeling) -->
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
        <div class="absolute top-[-10%] right-[-5%] w-[60%] h-[60%] rounded-full opacity-[0.18] dark:opacity-[0.12] blur-3xl bg-[var(--primary)]"></div>
        <div class="absolute top-[10%] left-[-10%] w-[55%] h-[55%] rounded-full opacity-[0.14] dark:opacity-[0.08] blur-3xl bg-violet-400 dark:bg-violet-500"></div>
        <div class="absolute top-[40%] left-[20%] w-[40%] h-[40%] rounded-full opacity-[0.10] dark:opacity-[0.06] blur-3xl bg-amber-400 dark:bg-amber-500"></div>
    </div>

    <div class="relative pt-12 md:pt-20 lg:pt-24 pb-10 md:pb-14 max-w-5xl mx-auto">
        <!-- Badge -->
        <div class="reveal mb-6 md:mb-8 flex justify-center">
            <a href="/about/" class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-black/[0.04] dark:bg-white/[0.06] border border-black/[0.06] dark:border-white/[0.08] text-xs md:text-[0.78rem] text-black/65 dark:text-white/70 hover:bg-black/[0.07] dark:hover:bg-white/[0.09] transition group">
                <span class="inline-flex items-center justify-center w-4 h-4 rounded-full bg-[var(--primary)] text-white text-[0.55rem] font-bold">N</span>
                <span>Biblioteca técnica práctica</span>
                <Icon name="material-symbols:arrow-forward" class="w-3 h-3 opacity-50 group-hover:opacity-100 group-hover:translate-x-0.5 transition"></Icon>
            </a>
        </div>

        <!-- Massive headline -->
        <h1 class="reveal reveal-delay-1 text-center text-[2.6rem] sm:text-5xl md:text-6xl lg:text-7xl xl:text-[5.5rem] font-bold tracking-[-0.03em] leading-[1.02] text-[var(--deep-text)] dark:text-white">
            Conocimiento técnico,<br/>
            <span class="bg-gradient-to-r from-[var(--primary)] via-emerald-500 to-teal-500 bg-clip-text text-transparent">
                explicado simple.
            </span>
        </h1>

        <!-- Tagline -->
        <p class="reveal reveal-delay-2 mt-6 md:mt-8 text-center text-base md:text-xl text-black/60 dark:text-white/65 leading-[1.55] max-w-2xl mx-auto px-2">
            Arquitectura, construcción, maquinaria pesada e ingeniería básica.
            Sin tecnicismos innecesarios.
        </p>

        <!-- CTAs -->
        <div class="reveal reveal-delay-3 mt-9 md:mt-11 flex flex-col sm:flex-row items-center justify-center gap-3">
            <a href="#ultimos" class="group inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-[var(--deep-text)] dark:bg-white text-white dark:text-neutral-900 font-semibold text-sm md:text-base shadow-lg shadow-black/10 dark:shadow-white/5 hover:shadow-xl hover:shadow-black/20 dark:hover:shadow-white/10 hover:-translate-y-0.5 transition-all">
                Ver últimos artículos
                <Icon name="material-symbols:arrow-forward" class="w-4 h-4 transition group-hover:translate-x-1"></Icon>
            </a>
            <a href="/categorias/" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-black/[0.04] dark:bg-white/[0.06] border border-black/[0.08] dark:border-white/[0.1] text-[var(--deep-text)] dark:text-white/90 font-semibold text-sm md:text-base hover:bg-black/[0.07] dark:hover:bg-white/[0.09] hover:-translate-y-0.5 transition-all">
                Explorar por tema
            </a>
        </div>
    </div>
</section>
