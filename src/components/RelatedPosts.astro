---
import { getCollection } from 'astro:content';
import PostCard from "./PostCard.astro";
import { getPostUrlBySlug } from "../utils/url-utils";

interface Props {
    currentSlug: string;
    category?: string;
    relatedSlugs?: string[];
    tags?: string[];
    limit?: number;
}

const { currentSlug, category, relatedSlugs = [], tags = [], limit = 3 } = Astro.props;

const all = await getCollection('posts', ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
});

// 1) Manualmente referenciados via frontmatter `related`
const manual = all.filter(p => relatedSlugs.includes(p.slug) && p.slug !== currentSlug);

// 2) Misma categoría (excluyendo current y los ya en manual)
const sameCategory = all.filter(p =>
    p.slug !== currentSlug &&
    !manual.some(m => m.slug === p.slug) &&
    p.data.category === category
);

// 3) Por tags compartidos (fallback si no hay suficientes en categoría)
const byTags = all.filter(p =>
    p.slug !== currentSlug &&
    !manual.some(m => m.slug === p.slug) &&
    !sameCategory.some(s => s.slug === p.slug) &&
    p.data.tags?.some(t => tags.includes(t))
);

// Combinar manteniendo prioridad
const combined = [...manual, ...sameCategory, ...byTags].slice(0, limit);

// Si todavía no hay suficientes, completar con últimos posts
if (combined.length < limit) {
    const fillers = all
        .filter(p => p.slug !== currentSlug && !combined.some(c => c.slug === p.slug))
        .sort((a, b) => +new Date(b.data.published) - +new Date(a.data.published))
        .slice(0, limit - combined.length);
    combined.push(...fillers);
}
---

{combined.length > 0 && (
    <section class="mt-16 pt-10 border-t border-black/[0.08] dark:border-white/[0.1]">
        <div class="mb-7">
            <p class="text-[0.7rem] uppercase tracking-[0.18em] font-semibold text-[var(--primary)] mb-1.5">Sigue leyendo</p>
            <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-[var(--deep-text)] dark:text-white/95">
                Artículos relacionados
            </h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {combined.map(entry => (
                <PostCard
                    entry={entry}
                    title={entry.data.title}
                    tags={entry.data.tags}
                    category={entry.data.category}
                    published={entry.data.published}
                    url={getPostUrlBySlug(entry.slug)}
                    image={entry.data.image}
                    description={entry.data.description}
                    draft={entry.data.draft}
                    size="sm"
                />
            ))}
        </div>
    </section>
)}
