---
import path from "path";
import { Icon } from 'astro-icon/components';
import ImageWrapper from "./misc/ImageWrapper.astro";
import { getDir } from "../utils/url-utils";
import { getCategory, FORMATO_LABEL } from "../lib/categories";
import { img, isCdnRef, imgSrcset } from "../lib/images";

interface Props {
    class?: string;
    entry: any;
    title: string;
    url: string;
    published: Date;
    tags: string[];
    category: string;
    image: string;
    description: string;
    words: number;
    draft: boolean;
    style?: string;
    size?: 'sm' | 'md' | 'lg';
}

const { entry, title, url, published, tags, category, image, description, style, size = 'md' } = Astro.props;
const className = Astro.props.class;

const hasCover = image !== undefined && image !== null && image !== '';
const useCdn = hasCover && isCdnRef(image);
const cdnWidth = size === 'lg' ? 1600 : size === 'md' ? 1000 : 800;
const cdnHeight = size === 'lg' ? 900 : size === 'md' ? 625 : 500;
const cdnUrl = useCdn ? img(image, { width: cdnWidth, height: cdnHeight, crop: 'fill' }) : '';
const cdnSrcset = useCdn ? imgSrcset(image, size === 'sm' ? [400, 600, 800] : [600, 900, 1200, 1600]) : '';
const { remarkPluginFrontmatter } = await entry.render();

const cat = getCategory(category);
const formato = entry.data?.formato as string | undefined;
const formatoLabel = formato ? FORMATO_LABEL[formato] ?? formato : '';

const publishedFmt = new Date(published).toLocaleDateString('es', {
    day: 'numeric', month: 'short', year: 'numeric',
});

const aspectClass = size === 'lg' ? 'aspect-[16/9]' : 'aspect-[16/10]';
const titleSize = size === 'lg'
    ? 'text-2xl md:text-4xl'
    : size === 'sm'
        ? 'text-lg md:text-xl'
        : 'text-xl md:text-2xl';
const descSize = size === 'lg' ? 'text-base md:text-lg' : 'text-[0.95rem]';
const descClamp = size === 'sm' ? 'line-clamp-2' : 'line-clamp-3';
---

<article
    class:list={[
        "group relative",
        "rounded-2xl border border-black/[0.07] dark:border-white/[0.08] bg-white dark:bg-white/[0.03]",
        "shadow-sm shadow-black/[0.02] dark:shadow-black/30",
        "hover:shadow-xl hover:shadow-black/[0.07] dark:hover:shadow-black/40",
        "hover:-translate-y-1 hover:border-[var(--primary)]/30 dark:hover:border-[var(--primary)]/30",
        "transition-all duration-300",
        "overflow-hidden",
        className,
    ]}
    style={style}
>
    <a href={url} class="block">
        <!-- Cover -->
        <div class={`relative overflow-hidden ${aspectClass} ${cat?.bg ?? 'bg-gray-100 dark:bg-white/5'}`}>
            {useCdn ? (
                <img
                    src={cdnUrl}
                    srcset={cdnSrcset}
                    sizes={size === 'sm' ? '(max-width: 768px) 100vw, 33vw' : '(max-width: 768px) 100vw, 50vw'}
                    alt={`Portada: ${title}`}
                    loading="lazy"
                    decoding="async"
                    class="w-full h-full object-cover transition duration-700 group-hover:scale-[1.05]"
                />
            ) : hasCover ? (
                <ImageWrapper
                    src={image}
                    basePath={path.join("content/posts/", getDir(entry.id))}
                    alt={`Portada: ${title}`}
                    class="w-full h-full object-cover transition duration-700 group-hover:scale-[1.05]"
                />
            ) : (
                <div class="absolute inset-0 flex flex-col items-center justify-center transition duration-700 group-hover:scale-[1.05]">
                    {cat?.icon && (
                        <div class={cat.text}>
                            <Icon name={cat.icon} class={size === 'lg' ? 'w-24 h-24 md:w-32 md:h-32 opacity-70' : 'w-14 h-14 md:w-16 md:h-16 opacity-70'}></Icon>
                        </div>
                    )}
                    {cat && (
                        <span class={`mt-2 text-[0.7rem] uppercase tracking-[0.18em] font-semibold ${cat.text} opacity-60`}>
                            {cat.short}
                        </span>
                    )}
                </div>
            )}
            <!-- Sutil overlay en hover -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/0 to-black/0 group-hover:from-black/10 transition-all duration-300"></div>
        </div>

        <!-- Texto -->
        <div class="p-5 md:p-6">
            <!-- Kicker -->
            {cat && (
                <div class="flex items-center gap-2 mb-3">
                    <span class={`inline-flex items-center gap-1 text-[0.68rem] font-semibold uppercase tracking-[0.1em] px-2 py-0.5 rounded ${cat.chip}`}>
                        <Icon name={cat.icon} class="w-3 h-3"></Icon>
                        {cat.short}
                    </span>
                    {formatoLabel && (
                        <span class="text-[0.68rem] uppercase tracking-[0.1em] text-black/40 dark:text-white/40">
                            {formatoLabel}
                        </span>
                    )}
                </div>
            )}

            <!-- Headline -->
            <h3 class={`font-bold tracking-[-0.015em] leading-[1.2] text-[var(--deep-text)] dark:text-white/95 mb-2.5 group-hover:text-[var(--primary)] transition-colors duration-300 ${titleSize}`}>
                {title}
            </h3>

            <!-- Deck -->
            {description && size !== 'sm' && (
                <p class={`text-black/60 dark:text-white/60 leading-relaxed mb-4 ${descSize} ${descClamp}`}>
                    {description}
                </p>
            )}

            <!-- Meta -->
            <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-[0.78rem] text-black/45 dark:text-white/45">
                <time datetime={new Date(published).toISOString()}>{publishedFmt}</time>
                {remarkPluginFrontmatter?.minutes && (
                    <>
                        <span aria-hidden="true">·</span>
                        <span>{remarkPluginFrontmatter.minutes} min</span>
                    </>
                )}
                <span class="ml-auto inline-flex items-center gap-1 text-[var(--primary)] opacity-0 group-hover:opacity-100 -translate-x-1 group-hover:translate-x-0 transition-all duration-300 font-medium">
                    Leer
                    <Icon name="material-symbols:arrow-forward" class="w-3.5 h-3.5"></Icon>
                </span>
            </div>
        </div>
    </a>
</article>
